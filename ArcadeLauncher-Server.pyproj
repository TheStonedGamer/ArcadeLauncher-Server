<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{7F7E5E98-5E71-4D8C-8C84-5BEE34E82F3A}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>arcade_server.py</StartupFile>
    <SearchPath>$(ProjectHome)</SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>ArcadeLauncher-Server</Name>
    <RootNamespace>ArcadeLauncherServer</RootNamespace>
    <InterpreterId>Global|PythonCore|3.12</InterpreterId>
    <IsWindowsApplication>False</IsWindowsApplication>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
